{
  "extends": [
    "eslint-config-zemoso",
    "prettier",
    "plugin:storybook/recommended"
  ],
  "parser": "espree",
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module",
    "ecmaFeatures": {
      "jsx": true
    }
  },
  "env": {
    "browser": true,
    "es2022": true,
    "node": true
  }
}